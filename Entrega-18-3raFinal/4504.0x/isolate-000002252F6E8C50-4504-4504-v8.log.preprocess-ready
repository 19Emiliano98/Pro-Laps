script-source,172,file:///D:/User/Programacion/ProLaps/Entrega-16/routers/apiRandom.js,import { Router } from "express";\nimport { fork } from 'child_process';\nimport path from "path";\n\nconst apiRandom = Router();\n\napiRandom.get("/"\x2C (req\x2C res) => {\n\n    const cantidad = req.query.cant || 800000000;\n\n    const calculo = fork(path.resolve(process.cwd()\x2C './middleware/calculo.js'));\n    calculo.on('message'\x2C result => {\n        if (result == 'listo') {\n            calculo.send(cantidad);\n        } else {\n            res.json(result);\n        };\n    });\n});\n\nexport default apiRandom;
